FLASK_APP=wsgi.py
FLASK_CONFIG=dev
FLASK_DEBUG=1
SECRET_KEY=changeme-32-bytes-hex-please-replace

DATABASE_URL=mysql+pymysql://aquag20:senha@localhost:3306/aquag20?charset=utf8mb4
TEST_DATABASE_URL=mysql+pymysql://aquag20:senha@localhost:3306/aquag20_test?charset=utf8mb4

PERMANENT_SESSION_LIFETIME_MINUTES=480

ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=2

# --- Off-site backup S3-compatível (opcional — scripts/sync_backups_s3.py) ---
# Funciona com AWS S3, Backblaze B2, Oracle OCI, Cloudflare R2, Wasabi, MinIO.
# Setar S3_BACKUP_ENDPOINT_URL aponta pro provider; vazio = AWS.
# S3_BACKUP_BUCKET=meu-bucket-aquag20
# S3_BACKUP_PREFIX=aquag20-backups/
# S3_BACKUP_STORAGE_CLASS=STANDARD_IA          # AWS; deixe vazio "" pra B2/R2
# S3_BACKUP_ENDPOINT_URL=                       # vazio = AWS. Exemplos:
#   B2:  https://s3.us-west-002.backblazeb2.com
#   OCI: https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
#   R2:  https://<account>.r2.cloudflarestorage.com
# AWS_ACCESS_KEY_ID=...                         # usa mesmas envs pra todos os providers
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=sa-east-1                          # AWS region OU región equivalente do provider
# --- Object Lock (opcional, opt-in) — proteção anti-ransomware
# Cada upload fica lockado por N dias. Cap interno: 35 dias.
# Bucket precisa ter Object Lock habilitado NA CRIAÇÃO (não dá pra ativar depois).
# COMPLIANCE é IRREVERSÍVEL — nem suporte do provider apaga antes da data.
# S3_BACKUP_LOCK_MODE=COMPLIANCE                # ou GOVERNANCE
# S3_BACKUP_LOCK_RETENTION_DAYS=7

